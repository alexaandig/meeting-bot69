# ------------------------------------------------------------------------------
# Application
# ------------------------------------------------------------------------------

# The public URL of your application.
# This is used to construct redirect URLs for authentication and other services.
# Example: http://localhost:3000
NEXT_PUBLIC_APP_URL=

# ------------------------------------------------------------------------------
# Google
# ------------------------------------------------------------------------------

# To get your Google Client ID and Secret, follow these steps:
# 1. Go to the Google Cloud Console: https://console.cloud.google.com/
# 2. Create a new project or select an existing one.
# 3. Go to "APIs & Services" > "Credentials".
# 4. Click "Create Credentials" > "OAuth client ID".
# 5. Select "Web application" as the application type.
# 6. Add your authorized redirect URIs. For this application, it will be `${NEXT_PUBLIC_APP_URL}/api/auth/google/callback`.
# 7. Click "Create" and you will get your Client ID and Secret.
# For more information, see the documentation: https://support.google.com/cloud/answer/6158849
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=${NEXT_PUBLIC_APP_URL}/api/auth/google/callback


# ------------------------------------------------------------------------------
# Asana
# ------------------------------------------------------------------------------

# To get your Asana Client ID and Secret, follow these steps:
# 1. Go to the Asana Developer Console: https://app.asana.com/0/my-apps
# 2. Click "Create new app".
# 3. Fill in the app details.
# 4. Under "OAuth", add your redirect URL: `${NEXT_PUBLIC_APP_URL}/api/integrations/asana/callback`
# 5. You will then get your Client ID and Secret.
# For more information, see the documentation: https://developers.asana.com/docs/oauth
ASANA_CLIENT_ID=
ASANA_CLIENT_SECRET=

# ------------------------------------------------------------------------------
# Jira
# ------------------------------------------------------------------------------

# To get your Jira Client ID and Secret, follow these steps:
# 1. Go to the Atlassian Developer Console: https://developer.atlassian.com/console
# 2. Click "Create" > "OAuth 2.0 integration".
# 3. Fill in the app details.
# 4. Under "Authorization", add your callback URL: `${NEXT_PUBLIC_APP_URL}/api/integrations/jira/callback`
# 5. Go to "Permissions" and add the required scopes.
# 6. Go to "Settings" to find your Client ID and Secret.
# For more information, see the documentation: https://developer.atlassian.com/cloud/jira/platform/oauth-2-3lo-apps/
JIRA_CLIENT_ID=
JIRA_CLIENT_SECRET=

# ------------------------------------------------------------------------------
# Trello
# ------------------------------------------------------------------------------

# To get your Trello API Key, follow these steps:
# 1. Go to the Trello Power-Ups admin page: https://trello.com/power-ups/admin
# 2. Create a new Power-Up or select an existing one.
# 3. Go to the "API Key" tab and generate a new API key.
# 4. You will also need a token, which you can generate from the same page.
# For more information, see the documentation: https://developer.atlassian.com/cloud/trello/guides/rest-api/authorization/
TRELLO_API_KEY=

# ------------------------------------------------------------------------------
# Slack
# ------------------------------------------------------------------------------

# To get your Slack credentials, follow these steps:
# 1. Go to the Slack API Console: https://api.slack.com/apps
# 2. Click "Create New App".
# 3. Fill in the app details and select your workspace.
# 4. Go to "OAuth & Permissions" and add your redirect URL: `${NEXT_PUBLIC_APP_URL}/api/slack/oauth`
# 5. Add the required scopes under "User Token Scopes".
# 6. Go to "Basic Information" to find your Client ID, Client Secret, and Signing Secret.
# For more information, see the documentation: https://api.slack.com/authentication/oauth-v2
SLACK_CLIENT_ID=
SLACK_CLIENT_SECRET=
SLACK_SIGNING_SECRET=
SLACK_REDIRECT_URL=${NEXT_PUBLIC_APP_URL}/api/slack/oauth

# ------------------------------------------------------------------------------
# Stripe
# ------------------------------------------------------------------------------

# To get your Stripe API keys, follow these steps:
# 1. Go to the Stripe Dashboard: https://dashboard.stripe.com/
# 2. Go to "Developers" > "API keys".
# 3. You will find your Publishable key and Secret key.
# 4. To get your webhook signing secret, go to "Developers" > "Webhooks" and create a new webhook endpoint.
# For more information, see the documentation: https://stripe.com/docs/keys
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# ------------------------------------------------------------------------------
# AWS
# ------------------------------------------------------------------------------

# To get your AWS credentials, follow these steps:
# 1. Go to the AWS Management Console: https://console.aws.amazon.com/
# 2. Go to "IAM" > "Users" and select your user.
# 3. Go to the "Security credentials" tab and create a new access key.
# 4. You will get your Access Key ID and Secret Access Key.
# For more information, see the documentation: https://docs.aws.amazon.com/general/latest/gr/aws-sec-cred-types.html
# The S3 bucket name and region are specific to your setup.
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=
S3_BUCKET_NAME=

# ------------------------------------------------------------------------------
# Clerk
# ------------------------------------------------------------------------------

# To get your Clerk API keys, follow these steps:
# 1. Go to the Clerk Dashboard: https://dashboard.clerk.dev/
# 2. Create a new application or select an existing one.
# 3. Go to "API Keys" to find your Publishable Key and Secret Key.
# 4. To get your webhook signing secret, go to "Webhooks" and create a new webhook endpoint.
# For more information, see the documentation: https://clerk.com/docs/nextjs/quickstart
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=
CLERK_WEBHOOK_SECRET=
# These are optional, but recommended for a better user experience.
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/

# ------------------------------------------------------------------------------
# Database
# ------------------------------------------------------------------------------

# The connection string for your database.
# This is used by Prisma to connect to the database.
# The format depends on the database you are using (e.g., PostgreSQL, MySQL, SQLite).
# Example for PostgreSQL: postgresql://user:password@host:port/database
# For more information, see the documentation: https://www.prisma.io/docs/reference/database-reference/connection-urls
DATABASE_URL=

# ------------------------------------------------------------------------------
# Email
# ------------------------------------------------------------------------------

# To send emails with Gmail, you need to generate an app password.
# 1. Go to your Google Account settings: https://myaccount.google.com/security
# 2. Enable 2-Step Verification.
# 3. Go to "App passwords" and generate a new password for mail.
# For more information, see the documentation: https://support.google.com/accounts/answer/185833
GMAIL_USER=
GMAIL_APP_PASSWORD=

# To use Resend for sending emails, you need an API key.
# 1. Go to the Resend Dashboard: https://resend.com/
# 2. Go to "API Keys" and create a new API key.
# For more information, see the documentation: https://resend.com/docs/dashboard/api-keys/introduction
RESEND_API_KEY=

# ------------------------------------------------------------------------------
# AI
# ------------------------------------------------------------------------------

# To use the Gemini API, you need an API key.
# 1. Go to Google AI Studio: https://aistudio.google.com/
# 2. Create a new API key.
# For more information, see the documentation: https://ai.google.dev/gemini-api/docs/api-key
GEMINI_API_KEY=

# To use Pinecone, you need an API key and an index name.
# 1. Go to the Pinecone console: https://app.pinecone.io/
# 2. Create a new project and an index.
# 3. Go to "API Keys" to find your API key.
# The index name is the name you gave to your index.
# For more information, see the documentation: https://docs.pinecone.io/guides/projects/manage-api-keys
PINECONE_API_KEY=
PINECONE_INDEX_NAME=